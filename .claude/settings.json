{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node tools/verify.cjs)",
      "Bash(node tools/generate.cjs:*)",
      "Bash(node build-standalone.cjs)",
      "Bash(node --check:*)",
      "Bash(python3 -m http.server:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/verify-gate.sh" }
        ]
      }
    ]
  }
}
